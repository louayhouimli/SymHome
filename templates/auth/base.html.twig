<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}SymHome - Auth{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.3/dist/lux/bootstrap.min.css" rel="stylesheet">

    <style>
        html, body {
            margin: 0;
            padding: 0;
            overflow: hidden;
        }

        body {
            min-height: 100vh;
        }


        .auth-header {
            position: absolute;
            top: 20px;
            left: 30px;
            z-index: 10;
            color: white;
        }

        .auth-page {
            min-height: 100vh;
            display: flex;
        }

        .auth-left {
            flex: 1;
            background: url('https://images.unsplash.com/photo-1505691938895-1758d7feb511') center/cover no-repeat;
            position: relative;
        }

        .auth-left::after {
            content: "";
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.35);
        }

        .auth-right {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            gap: 60px;
            background: #f8f9fa;
            padding: 40px;
        }

        .auth-brand h1 {
            font-weight: bold;
            margin: 0;
        }

        .auth-brand h3 {
            font-size: 18px;
            color: #666;
        }

        .auth-card {
            width: 100%;
            max-width: 650px;
            padding: 70px;
            background: white;
            border-radius: 16px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.12);
        }

        @media (max-width: 768px) {
            .auth-page {
                flex-direction: column;
            }

            .auth-left {
                height: 220px;
            }

            .auth-card {
                max-width: 95%;
                padding: 35px;
            }
        }
        form {
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        input, select, textarea {
            width: 100%;
            padding: 14px;
            border-radius: 10px;
            border: 1px solid #ddd;
            background: #faf8f5;
            font-size: 15px;
            box-sizing: border-box;
        }

        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: #a67c52;
            box-shadow: 0 0 0 3px rgba(166,124,82,0.15);
        }

        button, .btn {
            margin-top: 12px;
            padding: 14px;
            border: none;
            border-radius: 10px;
            background: #6b4f3a;
            color: white;
            font-size: 16px;
            cursor: pointer;
            width: 100%;
        }

        button:hover, .btn:hover {
            background: #5a3f2d;
        }

        label {
            font-size: 13px;
            color: #5a4a42;
            margin-bottom: 4px;
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>

<body>

<div class="auth-page">

    <div class="auth-left"></div>

    <div class="auth-right">

        <div class="auth-brand text-center">
            {% block auth_title %}
                <h1>SymHome</h1>
                <h3>Meubles & décoration</h3>
            {% endblock %}
        </div>

        <div class="auth-card">
            {% block auth_content %}{% endblock %}
        </div>

    </div>

</div>

</body>
</html>