{% extends 'admin/base.html.twig' %}

{% block body %}

<div class="mb-4">
    <h2 class="fw-bold">Ajouter un meuble</h2>
</div>

<div class="card shadow-sm border-0 p-4">

    {{ form_start(form) }}

    <div class="mb-3">
        {{ form_label(form.nom) }}
        {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.prix) }}
        {{ form_widget(form.prix, {'attr': {'class': 'form-control'}}) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.description) }}
        {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.image) }}
        {{ form_widget(form.image, {'attr': {'class': 'form-control'}}) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.stock) }}
        {{ form_widget(form.stock, {'attr': {'class': 'form-control'}}) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.categorie) }}
        {{ form_widget(form.categorie, {'attr': {'class': 'form-select'}}) }}
    </div>

    <button class="btn text-white" style="background-color: #5D4037;">
        Enregistrer
    </button>

    {{ form_end(form) }}

</div>

{% endblock %}