{% extends 'client/base.html.twig' %}

{% block title %}
    {{ meuble.nom }}
{% endblock %}

{% block body %}

<div class="container">

    <div class="card card-product">

        <div class="row g-0">
            <div class="col-md-6">

                <img
                    src="/uploads/{{ meuble.image }}"
                    alt="{{ meuble.nom }}"
                    class="img-fluid w-100 h-100"
                    style="object-fit: cover; max-height:100%"
                >

            </div>

            <div class="col-md-6 d-flex align-items-center">

                <div class="card-body p-5">

                    <span class="badge rounded-pill mb-3 px-3 py-2"
                          style="background-color: #EFEBE9; color: #5D4037;">

                        {{ meuble.categorie.libelle }}

                    </span>

                    <h1 class="card-title" style="font-size: 2.5rem;">

                        {{ meuble.nom }}

                    </h1>

                    <div class="card-price" style="font-size: 2rem;">

                        {{ meuble.prix }} DT

                    </div>

                    <p class="card-text fs-5">

                        {{ meuble.description }}

                    </p>

                    <div class="mb-4">

                        {% if meuble.stock > 0 %}

                            <span class="badge bg-success fs-6 px-3 py-2">
                                En stock ({{ meuble.stock }})
                            </span>

                        {% else %}

                            <span class="badge bg-danger fs-6 px-3 py-2">
                                Rupture de stock
                            </span>

                        {% endif %}

                    </div>

                    <div class="d-flex gap-3">

                        <button
                            class="btn btn-buy text-white"
                            onclick="addToCart({{ meuble.id }}, '{{ meuble.nom|e('js') }}', {{ meuble.prix }}, '{{ meuble.image|e('js') }}')"
                            {% if meuble.stock == 0 %}disabled{% endif %}
                        >
                            Ajouter au panier
                        </button>

                        <a href="{{ path('app_client') }}"
                           class="btn btn-outline-secondary btn-xl px-4">

                            Retour

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

{% endblock %}