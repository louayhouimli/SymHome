{% extends 'client/base.html.twig' %}

{% block title %}Nos meubles{% endblock %}

{% block body %}

<style>
    .product-card-custom {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .product-card-custom:hover {
        transform: translateY(-8px);
    }

    .product-card-custom img {
        height: 240px;
        object-fit: cover;
    }

    .btn-buy {
        background: linear-gradient(90deg, #5D4037, #795548);
        border: none;
        transition: all 0.2s;
    }

    .btn-buy:hover {
        transform: translateY(-2px);
        background: linear-gradient(90deg, #4E342E, #6D4C41);
        color: white;
    }
</style>

<!-- TITLE -->
<h2 class="h2 fw-bold text-center mb-5" style="color: #4E342E;">
    Nos Meubles
</h2>

<!-- PRODUCTS -->
<div class="row g-4 justify-content-center">

    {% for meuble in meubles %}

        <div class="col-md-6 col-lg-4 d-flex justify-content-center">
            <div class="card product-card-custom" style="width: 100%; max-width: 400px;">

                <img src="{{ meuble.image }}" class="card-img-top" alt="meuble">

                <div class="card-body">

                    <h5 class="card-title" style="color: #3E2723;">{{ meuble.nom }}</h5>

                    <div class="h5" style="color: #6D4C41;">
                        {{ meuble.prix }} DT
                    </div>

                    <p class="card-text text-muted" style="min-height: 60px;">
                        {{ meuble.description }}
                    </p>

                    <button class="btn btn-buy w-100 text-white">
                        Ajouter au panier
                    </button>

                </div>

            </div>
        </div>

    {% else %}

        <div class="alert alert-warning">
            Aucun meuble disponible
        </div>

    {% endfor %}

</div>

{% endblock %}