<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.3/dist/lux/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <title>{% block title %}SymHome - Meubles & Décoration{% endblock %}</title>

    <style>
        .hero-section {
            background: linear-gradient(rgba(0,0,0,0.45), rgba(0,0,0,0.45)),
                        url('https://images.unsplash.com/photo-1505693416388-ac5ce068fe85')
                        center/cover no-repeat;
            height: 420px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 50px;
            border-radius: 8px;
        }

        .hero-content {
            text-align: center;
            color: white;
        }

        .hero-content h1 {
            font-size: 58px;
            font-weight: bold;
            margin-bottom: 15px;
        }

        .hero-content p {
            font-size: 20px;
            opacity: 0.9;
        }

        .search-navbar {
            min-width: 400px;
        }

        .card-product {
            border: none;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            border-radius: 12px;
            width:90%;
            overflow: hidden;
            transition: transform 0.25s ease, box-shadow 0.25s ease;
            height: 100%;
        }

        .card-product:hover {
            transform: translateY(-8px);
        }

        .card-product img {
            height: 240px;
            object-fit: cover;
        }

        .btn-buy {
            background: linear-gradient(90deg, #5D4037, #795548);
            border: none;
            color: white;
            font-weight: bold;
        }

        .btn-buy:hover {
            background: linear-gradient(90deg, #4E342E, #6D4C41);
            color: white;
        }
    </style>
</head>

<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark shadow-sm" style="background-color: #5D4037;">
    <div class="container">

        <a class="navbar-brand fw-bold" href="{{ path('app_client') }}">
            SymHome
        </a>

        <form method="GET" id="filterForm" class="d-flex gap-2">

            <input
                type="text"
                name="recherche"
                class="form-control"
                placeholder="Rechercher..."
                oninput="this.form.submit()"
            >

            <select name="categorie"
                    class="form-select"
                    onchange="this.form.submit()">

                <option value="">Toutes catégories</option>

                {% for c in categories %}
                    <option value="{{ c.id }}">
                        {{ c.libelle }}
                    </option>
                {% endfor %}

            </select>

        </form>

        <div class="d-flex gap-2 ms-3">

            <a href="{{ path('app_panier') }}"
               class="btn btn-outline-light btn-sm position-relative">

                <i class="bi bi-cart"></i> Panier

                <span id="cart-count"
                      class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                    0
                </span>

            </a>

            <a href="{{ path('user_login') }}"
               class="btn btn-outline-light btn-sm">
                Déconnexion
            </a>

        </div>

    </div>
</nav>

<div class="container py-5">


    {% block body %}{% endblock %}

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/js/bootstrap.bundle.min.js"></script>

<script>

function getCart()
{
    return JSON.parse(localStorage.getItem('cart')) || [];
}

function saveCart(cart)
{
    localStorage.setItem('cart', JSON.stringify(cart));
}

function addToCart(id, nom, prix, image)
{
    let cart = getCart();

    let item = cart.find(p => p.id == id);

    if (item) {
        item.quantite += 1;
    } else {
        cart.push({
            id: id,
            nom: nom,
            prix: prix,
            image: image,
            quantite: 1
        });
    }

    saveCart(cart);
    updateCartCount();
}

function updateCartCount()
{
    let cart = getCart();

    let count = cart.reduce((sum, item) => sum + item.quantite, 0);

    let el = document.getElementById("cart-count");

    if (el) el.innerText = count;
}

document.addEventListener("DOMContentLoaded", updateCartCount);

</script>

</body>
</html>