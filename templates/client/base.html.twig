<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.3/dist/lux/bootstrap.min.css" rel="stylesheet">
    <title>{% block title %}SymHome - Meubles & Décoration{% endblock %}</title>
    <style>
        .hero-section {
            background: linear-gradient(rgba(0,0,0,0.45), rgba(0,0,0,0.45)), url('https://images.unsplash.com/photo-1505693416388-ac5ce068fe85') center/cover no-repeat;
            height: 420px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 50px;
            border-radius: 8px;
        }

        .hero-content {
            text-align: center;
            color: white;
        }

        .hero-content h1 {
            font-size: 58px;
            font-weight: bold;
            margin-bottom: 15px;
        }

        .hero-content p {
            font-size: 20px;
            opacity: 0.9;
        }

        .search-navbar {
            min-width: 400px;
        }

        .search-navbar .form-control {
            background-color: rgba(255, 255, 255, 0.9);
            border: none;
            padding: 0.5rem 1rem;
            font-size: 0.95rem;
        }

        .search-navbar .form-control::placeholder {
            color: #999;
        }

        .search-navbar .btn-outline-light {
            border-color: rgba(255, 255, 255, 0.5);
            padding: 0.5rem 1rem;
            font-size: 0.95rem;
        }
    </style>
</head>
<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark shadow-sm" style="background-color: #5D4037;">
    <div class="container">
        <a class="navbar-brand fw-bold" href="{{ path('app_client') }}">SymHome</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
        <form method="GET" class="search-navbar ms-auto me-3">
            <div class="input-group">
                <input 
                    type="text"
                    placeholder="Rechercher..."
                    id="recherche"
                    name="recherche"
                    class="form-control"
                    oninput="this.form.submit()"
                >
            </div>
        </form>
            <div class="navbar-nav">
                <a class="nav-link" href="{{ path('app_client') }}">Accueil</a>
                <a class="nav-link" href="">Produits</a>
                <a class="nav-link" href="">Catégories</a>
            </div>
        </div>
        <div class="d-flex gap-2 ms-3">
            <a href="" class="btn btn-outline-light btn-sm">Panier</a>
            <a href="{{ path('user_login') }}" class="btn btn-outline-light btn-sm">Déconnexion</a>
        </div>
    </div>
</nav>

<div class="container py-5">
    

    <!-- HERO -->
    <div class="hero-section mb-5">
        <div class="hero-content">
            <h1 style="color : white">SymHome</h1>
            <p>Meubles modernes & décoration élégante</p>
        </div>
    </div>

    {% block body %}{% endblock %}
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/js/bootstrap.bundle.min.js"></script>
</body>
</html>